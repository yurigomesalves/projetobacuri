# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# arquivos de ambiente (chaves de API — NUNCA versionar)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pipeline — documentos baixados e dados intermediários (pesados; ficam só na máquina local)
/pipeline/dados/
# logs de OCR/processamento do pipeline (só na máquina local)
/pipeline/*.log

# python
__pycache__/
*.pyc
.venv/

# arquivos temporários do LibreOffice e kit de instalação
.~lock.*
/kit-projetobacuri/
/kit-projetobacuri.zip
