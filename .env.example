# =============================================================
# Memória e Verdade — variáveis de ambiente (MODELO)
#
# Como usar: copie este arquivo para `.env.local` e preencha os
# valores reais. O `.env.local` NUNCA é enviado ao GitHub (está
# protegido pelo .gitignore). Este modelo, sem segredos, é
# versionado para documentar o que o projeto precisa.
# =============================================================

# --- Supabase (banco de dados Postgres + busca vetorial) ---
# Encontrados em: painel do Supabase > Project Settings > API

# URL pública do projeto Supabase (pode aparecer no navegador, não é segredo)
NEXT_PUBLIC_SUPABASE_URL=

# Chave "anon" / publishable — acesso público de leitura, limitado pelas
# políticas de segurança (RLS) do banco
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave "service_role" — ACESSO TOTAL ao banco. Só usada no servidor
# (rotas de API e scripts do pipeline). JAMAIS expor no navegador.
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM de geração (o "cérebro" que redige as respostas) ---
# Qual provedor usar: "groq" (padrão, free tier), "openrouter" ou "ollama"
LLM_PROVIDER=groq

# Chave da API do Groq (https://console.groq.com)
GROQ_API_KEY=

# Chave da API do OpenRouter (https://openrouter.ai) — alternativa ao Groq
OPENROUTER_API_KEY=

# Modelo de geração (obrigatório para openrouter e ollama; opcional no groq).
# Ex.: google/gemma-4-31b-it:free (OpenRouter, gratuito, bom em português)
LLM_MODELO=

# --- Curadoria (Fase 4) ---
# Senha das rotas protegidas de curadoria (Authorization: Bearer <senha>).
# Sem esta variável definida, as rotas de curadoria respondem 401 sempre.
CURADORIA_SENHA=
