{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },

  "permission": {
    "*": "ask",

    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",

    "edit": "ask",

    "bash": {
      "*": "ask",
      "npm *": "allow",
      "yarn *": "allow",
      "npx *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "mkdir *": "ask",
      "cp *": "ask",
      "rm *": "ask"
    },

    "webfetch": "allow",
    "websearch": "allow"
  }
}